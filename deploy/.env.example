# Hydropark local-stack environment (deploy/docker-compose.yml).
#
# Copy this file to `.env` in the same directory (deploy/up.ps1 does this for
# you if `.env` is missing) and fill in the placeholders. `.env` is read
# automatically by `docker compose` because it lives next to
# docker-compose.yml - do not rename or move it.
#
# ******************************************************************
# ** HP_LICENSE_PRIVATE_KEY must reach ONLY the `issuer` service.   **
# ** docker-compose.yml enforces this by never referencing this var **
# ** in the `api` or `worker` service blocks - do not add it there. **
# ******************************************************************
#
# Never commit a filled-in `.env`. This `.env.example` is the only file
# meant to be checked in.

# -----------------------------------------------------------------------
# Zone-crossing secret. Shared by api/issuer/worker so `api` can call the
# internal-only issuer/worker over HP_ISSUER_URL / HP_WORKER_URL
# (InternalHttpConfig.java, header X-Internal-Token). Any long random
# string is fine for local dev - generate one with, e.g.:
#   powershell -c "[guid]::NewGuid().ToString('N') + [guid]::NewGuid().ToString('N')"
# -----------------------------------------------------------------------
HP_INTERNAL_TOKEN=REPLACE_ME_WITH_A_LONG_RANDOM_STRING

# -----------------------------------------------------------------------
# Internal mTLS (BACKEND-DESIGN §6.2, ticket P1-16.9) - OPT-IN, OFF by default.
# When false (default), the api->issuer / api->worker hop uses HP_INTERNAL_TOKEN
# above. When true, that hop is mutually authenticated with client certs and the
# token is no longer the server-side authenticator (mTLS replaces it; the Issuer
# STILL independently re-verifies settlement underneath - mTLS is defense in depth).
#
# To turn it on locally:
#   1. Generate the PKI:  .\scripts\generate-internal-certs.ps1   (writes ./certs/*.p12)
#   2. Uncomment/keep the four lines below (set the URLs to https on port 8443).
#   3. Restart the stack:  .\local\up.ps1
# docker-compose.yml already mounts ./certs at /certs and sets the per-zone
# keystore path (api.p12 / issuer.p12 / worker.p12) + truststore automatically.
# -----------------------------------------------------------------------
HP_INTERNAL_MTLS_ENABLED=false
# When enabling mTLS, also point the api at the https mTLS port of each zone:
#   HP_INTERNAL_MTLS_ENABLED=true
#   HP_ISSUER_URL=https://issuer:8443
#   HP_WORKER_URL=https://worker:8443
# Keystore/truststore password (must match what generate-internal-certs used;
# default "changeit"). Override there with HP_INTERNAL_MTLS_PASSWORD and here.
HP_INTERNAL_MTLS_PASSWORD=changeit
# HP_ISSUER_URL / HP_WORKER_URL default to http://issuer:8080 / http://worker:8080
# (mTLS off). Uncomment to switch to the mTLS port:
# HP_ISSUER_URL=https://issuer:8443
# HP_WORKER_URL=https://worker:8443

# -----------------------------------------------------------------------
# Access-token signing (RSA-2048, PKCS#8 private key, base64). Used by
# io.hydropark.security.AccessTokenService for RS256 app JWTs (§8).
# Blank is fine for local dev - the service generates an ephemeral key at
# boot and logs a warning; tokens just won't survive a container restart.
# Generate a real one with deploy/scripts/generate-keys.ps1.
# -----------------------------------------------------------------------
HP_JWT_PRIVATE_KEY=
HP_JWT_KEY_ID=hp-access-dev

# -----------------------------------------------------------------------
# License Issuer signing key (Ed25519, PKCS#8 private / X.509 public,
# base64 - BACKEND-DESIGN §6.1/§6.2). Generate with
# deploy/scripts/generate-keys.ps1. REQUIRED - docker-compose.yml's
# `issuer` service will refuse to start without these two set.
#
# HP_LICENSE_PRIVATE_KEY is the most sensitive secret in this file: a leak
# lets an attacker mint valid licenses for the entire catalog (BACKEND-
# DESIGN §11.2 #1, "keygen" scenario, §28.2). It must be readable by the
# `issuer` container only.
# -----------------------------------------------------------------------
HP_LICENSE_KID=hp-lic-dev
HP_LICENSE_PRIVATE_KEY=REPLACE_ME_RUN_deploy/scripts/generate-keys.ps1
HP_LICENSE_PUBLIC_KEY=REPLACE_ME_RUN_deploy/scripts/generate-keys.ps1

# -----------------------------------------------------------------------
# Payments (BACKEND-DESIGN §7). `fake` needs no credentials at all and is
# what the local stack uses by default - the whole compose stack runs with
# zero payment-provider secrets out of the box.
#
# To flip to real Stripe test-mode payments:
#   1. HP_PAYMENT_PROVIDER=stripe
#   2. HP_STRIPE_API_KEY=sk_test_...              (api + worker)
#   3. HP_STRIPE_WEBHOOK_SECRET=whsec_...         (worker ONLY - see below)
#   4. Point Stripe's test webhook at the local `worker` via the Stripe CLI:
#        stripe listen --forward-to localhost:8080/v1/webhooks/mor
#      (`worker` publishes no port, so forward to `api`'s published 8080 -
#      `api`'s receive-only handler enqueues; `worker` picks it up
#      internally. See deploy/README.md "Switching fake -> stripe".)
# -----------------------------------------------------------------------
HP_PAYMENT_PROVIDER=fake
HP_STRIPE_API_KEY=
# HP_STRIPE_WEBHOOK_SECRET is read ONLY by the `worker` service in
# docker-compose.yml (never `api`) - AGENT-CONTRACT.md security property #4:
# webhook verification happens in the worker, never at the public edge.
HP_STRIPE_WEBHOOK_SECRET=
HP_CHECKOUT_SUCCESS_URL=hydropark://purchase/callback
HP_CHECKOUT_CANCEL_URL=hydropark://purchase/cancel

# -----------------------------------------------------------------------
# Seeding & logging.
# -----------------------------------------------------------------------
# Set to true by deploy/local/seed.ps1 automatically; leave false for a
# plain `up.ps1` if you don't want seed catalog data.
HP_SEED_ENABLED=false
LOG_LEVEL=INFO

# -----------------------------------------------------------------------
# NOT in this file: MONGODB_URI. docker-compose.yml sets it directly to
# the compose-internal replica set (mongodb://mongo:27017/hydropark?replicaSet=rs0)
# for every service - there is nothing to configure locally. The cloud path
# (deploy/fly/*) uses three DIFFERENT Atlas connection strings, one per
# trust zone, set via `fly secrets` - see deploy/fly/bootstrap-secrets.ps1
# and deploy/fly/atlas-roles.js.
# -----------------------------------------------------------------------

# DEV ONLY: log verification/step-up codes in cleartext so local smoke tests can complete a
# step-up flow. NEVER set this to true in any deployed environment.
HP_AUTH_LOG_CODES=false
